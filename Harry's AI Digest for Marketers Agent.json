{
    "name": "Integration Gmail, Anthropic Claude, Slack",
    "flow": [
        {
            "id": 1,
            "module": "google-email:executeEmailSearchQuery",
            "version": 4,
            "parameters": {
                "__IMTCONN__": 1
            },
            "mapper": {
                "date": {
                    "from": "{{addHours(now; -24)}}"
                },
                "size": {
                    "unit": "M",
                    "criteria": "larger"
                },
                "limit": "5",
                "folder": "INBOX",
                "format": "full",
                "criteria": "all",
                "filterType": "simpleSearch",
                "hasAttachment": false,
                "includeHtmlBody": false
            },
            "metadata": {
                "designer": {
                    "x": -192,
                    "y": 3
                },
                "restore": {
                    "expect": {
                        "date": {
                            "collapsed": true
                        },
                        "size": {
                            "nested": {
                                "unit": {
                                    "mode": "chose",
                                    "label": "MB (megabytes)"
                                },
                                "criteria": {
                                    "mode": "chose",
                                    "label": "Greater than"
                                }
                            }
                        },
                        "folder": {
                            "mode": "chose",
                            "label": "Inbox"
                        },
                        "format": {
                            "mode": "chose",
                            "label": "Full content"
                        },
                        "criteria": {
                            "mode": "chose",
                            "label": "All messages"
                        },
                        "labelIds": {
                            "mode": "chose"
                        },
                        "filterType": {
                            "mode": "chose",
                            "label": "Simple filter"
                        },
                        "hasAttachment": {
                            "mode": "chose"
                        },
                        "includeHtmlBody": {
                            "mode": "chose"
                        }
                    },
                    "parameters": {
                        "__IMTCONN__": {
                            "data": {
                                "scoped": "true",
                                "connection": "google-email"
