        {
            "id": 9,
            "module": "util:TextAggregator",
            "version": 1,
            "parameters": {
                "feeder": 1,
                "rowSeparator": ""
            },
            "mapper": {
                "value": "{{1.fullTextBody}}"
            },
            "metadata": {
                "designer": {
                    "x": 251,
                    "y": 0
                },
                "restore": {
                    "extra": {
                        "feeder": {
                            "label": "Gmail - Search emails [1]"
                        }
                    },
                    "parameters": {
                        "rowSeparator": {
                            "label": "Empty"
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "rowSeparator",
                        "type": "select",
                        "label": "Row separator",
                        "validate": {
                            "enum": [
                                "\n",
                                "\t",
                                "other"
                            ]
                        }
                    }
                ],
                "expect": [
                    {
                        "name": "value",
                        "type": "text",
                        "label": "Text"
                    }
                ],
                "advanced": true
            }
        },
        {
            "id": 2,
            "module": "anthropic-claude:simpleTextPrompt",
            "version": 1,
            "parameters": {},
            "mapper": {
                "model": "claude-haiku-4-5",
                "max_tokens": "1000",
                "textPrompt": "You are a personal briefing assistant for a creative tech marketer. You will be given the contents of an email newsletter. Extract only the most genuinely insightful updates — ignore filler, sponsored content, and anything generic. Focus on updates relevant to these specific interests: AI tools and developments worth knowing about, marketing strategy and execution, content and SEO, design trends and tools, and vibe coding or no-code/low-code building. Prioritise anything that would meaningfully help someone grow as a creative marketer or move closer to working independently in the tech space. Summarise in 3–5 bullet points maximum — each one sharp, specific, and actionable. If nothing in the newsletter clears the bar, say so in one sentence rather than padding it out.\n\nHere is the newsletter content: \n{{`9`}}\n\nFormat your response exactly like this:\n🗞 Hazza's AI Digest — [today's date]\n─────────────────\nEach insight on its own line, starting with a bold headline, followed by the explanation. Put one blank line between each insight. No bullet points — just clean paragraphs. End with a single line:\n💡 That's your digest for today. Until next time...\n\nIMPORTANT FORMATTING RULES FOR SLACK:\n- To make text bold, wrap it in single asterisks like this: *bold text*\n- Never use double asterisks ** anywhere\n- Never use # for headers\n- Start each insight with a *bold headline* on the same line as the explanation\n"
            },
            "metadata": {
                "designer": {
                    "x": 649,
                    "y": -4
                },
                "restore": {
                    "expect": {
                        "model": {
                            "label": "Claude Haiku 4.5The quickest option, perfect for simple questions and instant, straightforward answers"
                        }
                    }
                },
                "expect": [
                    {
                        "name": "model",
                        "type": "select",
                        "label": "Model",
                        "required": true,
                        "validate": {
                            "enum": [
                                "claude-sonnet-4-6",
                                "claude-opus-4-6",
                                "claude-sonnet-4-5",
                                "claude-haiku-4-5",
                                "claude-opus-4-5"
                            ]
                        }
                    },
                    {
                        "name": "textPrompt",
                        "type": "text",
                        "label": "Text Prompt",
                        "required": true
                    },
                    {
                        "name": "max_tokens",
                        "type": "uinteger",
                        "label": "Max Tokens",
                        "required": true
                    }
                ],
                "advanced": true
            }
        },
